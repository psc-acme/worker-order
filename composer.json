{
    "name": "psc-acme/worker-order",
    "description": "Package worker-order for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\WorkerOrder\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "illuminate/database": "^11.0",
        "aws/aws-sdk-php": "^3.332",
        "psc-acme/plugin-billing": "^1.0",
        "psc-acme/plugin-order": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "rector/rector": "^1.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}